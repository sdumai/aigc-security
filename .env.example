# Frontend runtime mode
# false = call local Node proxy; true = use browser-local mock data.
VITE_USE_MOCKS=false
VITE_DEV_API_PROXY_TARGET=http://localhost:3001

# Volc Ark API key, used by server/index.cjs only.
# Do not prefix this with VITE_; VITE_* variables may be exposed to browser code.
VOLC_ARK_API_KEY=your-volc-ark-api-key

# Optional model overrides. Defaults are already set in server/index.cjs.
VOLC_ARK_IMAGE_MODEL=doubao-seedream-4-0-250828
VOLC_ARK_T2V_MODEL=doubao-seedance-1-0-lite-t2v-250428
VOLC_ARK_I2V_MODEL=doubao-seedance-1-0-lite-i2v-250428

# Required for image/video understanding tasks: fake detection and safety detection.
VOLC_ARK_VISION_MODEL=your-vision-endpoint-id

# Required for Volc Visual APIs: face swap and SeedEdit.
VOLC_ACCESS_KEY=your-volc-access-key
VOLC_SECRET_KEY=your-volc-secret-key
